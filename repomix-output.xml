type Breakpoint = 'xs' | 'sm' | 'md' | 'lg' | 'xl' | 'navigationCollapse'

export const useBreakpoints = () => {
  const ref = useRef(document.body)

  const { width } = useDimensions(ref, [])

  const breakpoints: { [key in Breakpoint]: boolean } = {
    xs: width <= 360,
    sm: width <= 720,
