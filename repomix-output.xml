        onClick={() => {
          setSpamming(!isSpamming)
        }}
      >
        {isSpamming ? 'Spam [On]' : 'Spam [Off]'}
      </button>

      <button
        onClick={() => {
          Meteor.call('echo', 'Echo')
        }}
      >
        String
      </button>

      <button
